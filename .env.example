# SAP AI Core / Gen AI Hub credentials for the Predictive JIT workshop.
#
# 1. Copy this file to `.env`  ->  cp .env.example .env
# 2. Fill in the values from your SAP AI Core service key and deployments.
# 3. Save the file, then restart the notebook kernel.
#
# Do NOT commit your completed `.env` file. It contains secrets.

# --- SAP AI Core service key (OAuth client credentials) ---
AICORE_AUTH_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com
AICORE_CLIENT_ID=<client-id-from-service-key>
AICORE_CLIENT_SECRET=<client-secret-from-service-key>
AICORE_BASE_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=<your-resource-group>

# --- Model deployments ---
# SAP-RPT-1 tabular prediction deployment. Used by Exercise 1A, 1B, and 2.
# Provide the deployment BASE URL; the notebooks append `/predict` automatically.
RPT1_DEPLOYMENT_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com/v2/inference/deployments/<deployment-id>

# Gen AI Hub orchestration deployment (LLM agent). Used by Exercise 2 only.
ORCH_DEPLOYMENT_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com/v2/inference/deployments/<deployment-id>
